#!/usr/bin/env bash
# KIS Secret Guard — PreToolUse hook
# Bash, Write, Edit 도구 실행 전 secret 패턴 감지 및 차단
#
# stdin: {"tool_name": "...", "tool_input": {...}}
# exit 0: 허용 / exit {{BLOCK_EXIT}} + stderr: 차단

set -euo pipefail

INPUT=$(cat)

LOG_DIR="${{{PROJECT_DIR_VAR}}:-$(pwd)}/{{LOG_DIR}}"
mkdir -p "$LOG_DIR"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
TODAY="${TIMESTAMP:0:10}"

TOOL_NAME=$(python3 -c "
import sys, json
data = json.loads(sys.stdin.read())
print(data.get('tool_name', ''))
" <<< "$INPUT" 2>/dev/null || echo "")

# 감지할 패턴 (따옴표로 감싸진 실제 값만 대상)
SECRET_PATTERNS=(
    'appkey\s*=\s*["\x27][A-Za-z0-9]+'
    'appsecret\s*=\s*["\x27][A-Za-z0-9]+'
    'app_key\s*=\s*["\x27][A-Za-z0-9]+'
    'app_secret\s*=\s*["\x27][A-Za-z0-9]+'
    'APP_KEY\s*=\s*["\x27][A-Za-z0-9]+'
    'APP_SECRET\s*=\s*["\x27][A-Za-z0-9]+'
    'authorization:\s*Bearer\s+[A-Za-z0-9._-]+'
    'approval_key\s*=\s*["\x27][A-Za-z0-9]+'
)

# 예외 파일 패턴 (변수명 언급만 있는 문서 파일)
EXEMPT_PATTERNS=('.gitignore' 'README' 'CLAUDE.md')

check_content() {
    local content="$1"
    local source_file="${2:-}"

    # 예외 파일 확인
    for exempt in "${EXEMPT_PATTERNS[@]}"; do
        if [[ "$source_file" == *"$exempt"* ]]; then
            exit 0
        fi
    done

    # 패턴 감지
    for pattern in "${SECRET_PATTERNS[@]}"; do
        if echo "$content" | python3 -c "
import sys, re
content = sys.stdin.read()
pattern = r'$pattern'
m = re.search(pattern, content, re.IGNORECASE)
if m:
    print(m.group(0)[:60])
    sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
            MATCHED=$(echo "$content" | python3 -c "
import sys, re
content = sys.stdin.read()
pattern = r'$pattern'
m = re.search(pattern, content, re.IGNORECASE)
if m:
    print(m.group(0)[:60])
" 2>/dev/null || echo "$pattern")
            echo "[KIS SECURITY] secret 패턴 감지: ${MATCHED} — 실행 차단됨" >&2
            echo "민감한 값을 직접 코드에 포함하지 마세요. 환경변수 또는 설정 파일을 사용하세요." >&2
            exit {{BLOCK_EXIT}}
        fi
    done
}

case "$TOOL_NAME" in
    Bash)
        COMMAND=$(python3 -c "
import sys, json
data = json.loads(sys.stdin.read())
print(data.get('tool_input', {}).get('command', ''))
" <<< "$INPUT" 2>/dev/null || echo "")
        echo "[$TIMESTAMP] secret-guard | tool: Bash | cmd: ${COMMAND:0:80}" >> "$LOG_DIR/kis-hooks-${TODAY}.log"
        check_content "$COMMAND"
        ;;
    Write)
        FILE_PATH=$(python3 -c "
import sys, json
data = json.loads(sys.stdin.read())
print(data.get('tool_input', {}).get('file_path', ''))
" <<< "$INPUT" 2>/dev/null || echo "")
        CONTENT=$(python3 -c "
import sys, json
data = json.loads(sys.stdin.read())
print(data.get('tool_input', {}).get('content', ''))
" <<< "$INPUT" 2>/dev/null || echo "")
        echo "[$TIMESTAMP] secret-guard | tool: Write | file: $FILE_PATH" >> "$LOG_DIR/kis-hooks-${TODAY}.log"
        check_content "$CONTENT" "$FILE_PATH"
        ;;
    Edit)
        FILE_PATH=$(python3 -c "
import sys, json
data = json.loads(sys.stdin.read())
print(data.get('tool_input', {}).get('file_path', ''))
" <<< "$INPUT" 2>/dev/null || echo "")
        NEW_STRING=$(python3 -c "
import sys, json
data = json.loads(sys.stdin.read())
print(data.get('tool_input', {}).get('new_string', ''))
" <<< "$INPUT" 2>/dev/null || echo "")
        echo "[$TIMESTAMP] secret-guard | tool: Edit | file: $FILE_PATH" >> "$LOG_DIR/kis-hooks-${TODAY}.log"
        check_content "$NEW_STRING" "$FILE_PATH"
        ;;
    *)
        # matcher에 걸리지 않은 tool — 로그만
        echo "[$TIMESTAMP] secret-guard | tool: ${TOOL_NAME:-unknown} | skip" >> "$LOG_DIR/kis-hooks-${TODAY}.log"
        ;;
esac

exit 0
